
@{
    ViewBag.Title = Model?.Nombre ?? "Detalle mascota";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-5">
            <img src="@(string.IsNullOrEmpty(Model.FotoUrl) ? "/Content/placeholder_pet.png" : Model.FotoUrl)" class="img-fluid rounded shadow" alt="@Model.Nombre" />
        </div>
        <div class="col-md-7">
            <h2 class="text-success">@Model.Nombre</h2>
            <p><strong>Tipo:</strong> @Model.Tipo</p>
            <p><strong>Edad:</strong> @Model.Edad aþos</p>
            <p><strong>Ubicaciµn actual:</strong> @Model.Ubicacion</p>
            <p><strong>Estado:</strong> @Model.Estado</p>
            <hr />
            <p>@Model.Descripcion</p>

            @if (Model.Estado == "Disponible")
            {
                <a class="btn btn-success" href="@Url.Action("Adopt","Mascotas", new { id = Model.Id })">Iniciar proceso de adopciµn</a>
            }
            else
            {
                <button class="btn btn-outline-secondary" disabled>No disponible para adopciµn</button>
            }

            <a class="btn btn-link ms-2" href="@Url.Action("Index","Mascotas")">Volver a lista</a>
        </div>
    </div>
</div>