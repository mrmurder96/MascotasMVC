@model Integrador.Models.Refugios
@{
    ViewBag.Title = "Eliminar Refugio";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col-md-8 col-md-offset-2">
            <div class="card">
                <div class="card-header bg-danger">
                    <h3><i class="glyphicon glyphicon-warning-sign"></i> Confirmar Eliminación</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>¡Atención!</strong> Está a punto de eliminar el siguiente refugio:
                    </div>

                    <dl class="dl-horizontal">
                        <dt>Nombre</dt>
                        <dd><strong>@Model.Nombre</strong></dd>

                        <dt>Responsable</dt>
                        <dd>@Model.NombreResponsable</dd>

                        <dt>Teléfono</dt>
                        <dd>@Model.Telefono</dd>

                        <dt>Email</dt>
                        <dd>@Model.Email</dd>

                        <dt>Dirección</dt>
                        <dd>@Model.Direccion</dd>

                        <dt>Mascotas</dt>
                        <dd>
                            <span class="badge">@Model.MascotasActuales mascotas albergadas</span>
                        </dd>
                    </dl>

                    @if (ViewBag.TieneMascotas != null && (bool)ViewBag.TieneMascotas)
                    {
                        <div class="alert alert-danger">
                            <strong><i class="glyphicon glyphicon-exclamation-sign"></i> Advertencia:</strong> Este refugio tiene mascotas asociadas.
                            No se puede eliminar hasta que se reasignen las mascotas.
                        </div>
                    }

                    <hr />

                    @using (Html.BeginForm("Delete", "Refugios", new { area = "Admin" }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.Id)

                        <div class="form-group">
                            <button type="submit" class="btn btn-danger btn-lg" @(ViewBag.TieneMascotas != null && (bool)ViewBag.TieneMascotas ? "disabled" : "")>
                                <i class="glyphicon glyphicon-trash"></i> Sí, Eliminar Refugio
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-default btn-lg">
                                <i class="glyphicon glyphicon-arrow-left"></i> Cancelar
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .dl-horizontal dt { width: 180px; font-weight: 600; }
    .dl-horizontal dd { margin-left: 200px; }
</style>
