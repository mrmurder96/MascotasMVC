@model IEnumerable<Integrador.Models.Mascotas>

@{
    ViewBag.Title = "Mascotas Disponibles - Pura Compañía";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section - Accesible con ARIA -->
<section class="mascotas-hero" role="region" aria-label="Sección de bienvenida - Encontrar compañero perfecto">
    <div class="hero-content">
        <h1><span aria-hidden="true">🐾</span> Encuentra a tu compañero perfecto</h1>
        <p class="subtitle">
            @if (Model != null && Model.Any())
            {
                <text>Tenemos <strong>@Model.Count()</strong> @(Model.Count() == 1 ? "mascota esperando" : "mascotas esperando") por un hogar lleno de amor</text>
            }
            else
            {
                <text>Descubre mascotas que buscan un hogar lleno de amor</text>
            }
        </p>
    </div>
</section>

<!-- Filtros Section - Accesible con ARIA -->
<section class="filtros-section" role="region" aria-label="Filtros de búsqueda">
    <div class="filtros-container">
        @using (Html.BeginForm("Index", "Mascotas", FormMethod.Get, new { @class = "filtros-form", role = "search", aria_label = "Formulario de búsqueda de mascotas" }))
        {
            <div class="filtro-group">
                <label for="buscar-input" id="buscar-label"><span aria-hidden="true">🔍</span> Buscar mascota</label>
                <input type="text" id="buscar-input" name="buscar" class="filtro-input" value="@ViewBag.Buscar" placeholder="Ingresa nombre de mascota..." aria-label="Campo de búsqueda por nombre de mascota" aria-describedby="buscar-help" />
                <small id="buscar-help" class="sr-only">Escribe el nombre de la mascota que buscas</small>
            </div>
            <div class="filtro-group">
                <label for="tipo-select" id="tipo-label"><span aria-hidden="true">🏷️</span> Tipo de mascota</label>
                <select id="tipo-select" name="tipo" class="filtro-select" aria-label="Filtrar por tipo de mascota" aria-describedby="tipo-help">
                    <option value="">Todos los tipos</option>
                    <option value="Perro" @(ViewBag.TipoSeleccionado == "Perro" ? "selected" : "")>Perro</option>
                    <option value="Gato" @(ViewBag.TipoSeleccionado == "Gato" ? "selected" : "")>Gato</option>
                    <option value="Ave" @(ViewBag.TipoSeleccionado == "Ave" ? "selected" : "")>Ave</option>
                    <option value="Conejo" @(ViewBag.TipoSeleccionado == "Conejo" ? "selected" : "")>Conejo</option>
                    <option value="Otro" @(ViewBag.TipoSeleccionado == "Otro" ? "selected" : "")>Otro</option>
                </select>
                <small id="tipo-help" class="sr-only">Selecciona el tipo de mascota que deseas adoptar</small>
            </div>
            <div class="filtro-group">
                <label for="tamano-select" id="tamano-label"><span aria-hidden="true">📏</span> Tamaño</label>
                <select id="tamano-select" name="tamano" class="filtro-select" aria-label="Filtrar por tamaño de mascota" aria-describedby="tamano-help">
                    <option value="">Todos los tamaños</option>
                    <option value="Pequeño" @(ViewBag.TamanoSeleccionado == "Pequeño" ? "selected" : "")>Pequeño</option>
                    <option value="Mediano" @(ViewBag.TamanoSeleccionado == "Mediano" ? "selected" : "")>Mediano</option>
                    <option value="Grande" @(ViewBag.TamanoSeleccionado == "Grande" ? "selected" : "")>Grande</option>
                </select>
                <small id="tamano-help" class="sr-only">Selecciona el tamaño de mascota preferido</small>
            </div>
            <div class="filtro-buttons">
                <button type="submit" class="btn-buscar" aria-label="Aplicar filtros de búsqueda">Buscar</button>
                <a href="@Url.Action("Index")" class="btn-limpiar" aria-label="Limpiar todos los filtros de búsqueda">Limpiar filtros</a>
            </div>
        }
    </div>
</section>

<!-- Grid de Mascotas - Accesible con ARIA -->
<section class="mascotas-section" role="region" aria-label="Listado de mascotas disponibles para adopción">
    @if (Model != null && Model.Any())
    {
        <div class="mascotas-grid" role="list" aria-label="@Model.Count() mascotas disponibles">
            @foreach (var mascota in Model)
            {
                <div class="mascota-card" role="listitem" aria-label="Mascota @mascota.Nombre, @(mascota.Tipo ?? "Tipo desconocido"), @(mascota.Edad?.ToString() ?? "Edad desconocida") años">
                    <article>
                        <div class="mascota-image-container">
                            @if (!string.IsNullOrEmpty(mascota.FotoUrl))
                            {
                                if (mascota.FotoUrl.StartsWith("/") || mascota.FotoUrl.StartsWith("~"))
                                {
                                    <img src="@Url.Content(mascota.FotoUrl)" alt="Foto de @mascota.Nombre, @(mascota.Tipo ?? "mascota")" class="mascota-image" />
                                }
                                else
                                {
                                    <img src="@Url.Content("~/Content/uploads/mascotas/" + mascota.FotoUrl)" alt="Foto de @mascota.Nombre, @(mascota.Tipo ?? "mascota")" class="mascota-image" />
                                }
                            }
                            else
                            {
                                <div class="mascota-image-placeholder" role="img" aria-label="Sin foto disponible"><span aria-hidden="true">🐾</span></div>
                            }
                            <span class="mascota-badge-disponible" aria-label="Mascota disponible para adopción">Disponible</span>
                        </div>
                        <div class="mascota-info">
                            <div class="mascota-header">
                                <h3>@mascota.Nombre</h3>
                                <span class="mascota-tag @(mascota.Tipo?.ToLower() == "gato" ? "gato" : mascota.Tipo?.ToLower() == "perro" ? "perro" : "otro")" role="status" aria-label="Tipo: @(mascota.Tipo ?? "Desconocido")">
                                    @mascota.Tipo
                                </span>
                            </div>
                            <p class="mascota-raza" aria-label="Raza: @(string.IsNullOrEmpty(mascota.Raza) ? "Mestizo" : mascota.Raza)">
                                @(string.IsNullOrEmpty(mascota.Raza) ? "Mestizo" : mascota.Raza)
                            </p>
                            <p class="mascota-edad" aria-label="Edad: @(mascota.Edad?.ToString() ?? "Desconocida") años @(!string.IsNullOrEmpty(mascota.Sexo) ? ", Sexo: " + mascota.Sexo : "")">
                                @(mascota.Edad.HasValue ? mascota.Edad + " años" : "Edad desconocida") @(!string.IsNullOrEmpty(mascota.Sexo) ? "• " + mascota.Sexo : "")
                            </p>
                            @if (!string.IsNullOrEmpty(mascota.Descripcion))
                            {
                                <p class="mascota-descripcion" aria-label="Descripción: @mascota.Descripcion">
                                    @(mascota.Descripcion.Length > 80 ? mascota.Descripcion.Substring(0, 77) + "..." : mascota.Descripcion)
                                </p>
                            }
                            <p class="mascota-ubicacion" aria-label="Ubicación: @(string.IsNullOrEmpty(mascota.Ubicacion) ? "Sin ubicación" : mascota.Ubicacion)">
                                <span aria-hidden="true">📍</span> @(string.IsNullOrEmpty(mascota.Ubicacion) ? "Sin ubicación" : mascota.Ubicacion)
                            </p>
                            <div class="mascota-buttons">
                                <a href="@Url.Action("Adopt", new { id = mascota.Id })" class="btn-adoptar" aria-label="Adoptar a @mascota.Nombre"><span aria-hidden="true">❤️</span> Adoptar</a>
                                <a href="@Url.Action("Details", new { id = mascota.Id })" class="btn-ver-mas" aria-label="Ver detalles completos de @mascota.Nombre">Ver más</a>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-mascotas" role="status" aria-label="No hay mascotas disponibles">
            <div class="no-mascotas-icon" aria-hidden="true">🐾</div>
            <h3>No hay mascotas disponibles en este momento</h3>
            <p>Vuelve pronto, constantemente recibimos nuevas mascotas buscando un hogar.</p>
            <a href="@Url.Action("Index", "MascotasPerdidas")" class="btn-alternativo" aria-label="Ver listado de mascotas perdidas">Ver Mascotas Perdidas</a>
        </div>
    }
</section>

<style>
    /* Hero Section */
    .mascotas-hero {
        background: linear-gradient(135deg, #BBFA8C 0%, #A5E88A 100%);
        padding: 60px 20px;
        text-align: center;
    }

    .mascotas-hero .hero-content {
        max-width: 800px;
        margin: 0 auto;
    }

    .mascotas-hero h1 {
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 42px;
        color: #000;
        margin: 0 0 16px 0;
    }

    .mascotas-hero .subtitle {
        font-family: 'Nunito', sans-serif;
        font-size: 20px;
        color: #333;
        margin: 0;
    }

    /* Filtros Section */
    .filtros-section {
        background: #FFFFFF;
        padding: 30px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .filtros-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .filtros-form {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        align-items: flex-end;
        justify-content: center;
    }

    .filtro-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .filtro-group label {
        font-family: 'Nunito', sans-serif;
        font-weight: 700;
        font-size: 14px;
        color: #333;
    }

    .filtro-input, .filtro-select {
        height: 48px;
        padding: 0 16px;
        border: 2px solid #e0e0e0;
        border-radius: 24px;
        font-family: 'Nunito', sans-serif;
        font-size: 15px;
        min-width: 180px;
        transition: border-color 0.3s, box-shadow 0.3s;
    }

    .filtro-input:focus, .filtro-select:focus {
        outline: none;
        border-color: #BBFA8C;
        box-shadow: 0 0 0 3px rgba(187, 250, 140, 0.3);
    }

    .filtro-buttons {
        display: flex;
        gap: 12px;
    }

    .btn-buscar {
        background: #BBFA8C;
        color: #000;
        height: 48px;
        padding: 0 28px;
        border: none;
        border-radius: 24px;
        font-family: 'Nunito', sans-serif;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.3s;
    }

    .btn-buscar:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(187, 250, 140, 0.4);
    }

    .btn-limpiar {
        background: transparent;
        color: #666;
        height: 48px;
        padding: 0 20px;
        border: 2px solid #e0e0e0;
        border-radius: 24px;
        font-family: 'Nunito', sans-serif;
        font-weight: 700;
        font-size: 15px;
        text-decoration: none;
        display: flex;
        align-items: center;
        transition: border-color 0.3s;
    }

    .btn-limpiar:hover {
        border-color: #999;
        color: #333;
        text-decoration: none;
    }

    /* Mascotas Section */
    .mascotas-section {
        background: rgba(0, 0, 0, 0.03);
        padding: 60px 20px;
    }

    .mascotas-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 30px;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Mascota Card */
    .mascota-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: transform 0.3s, box-shadow 0.3s;
        width: 100%;
        max-width: 320px;
        display: flex;
        flex-direction: column;
    }

    .mascota-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.15);
    }

    .mascota-image-container {
        position: relative;
        height: 280px;
        overflow: hidden;
        background: #f5f5f5;
    }

    .mascota-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s;
    }

    .mascota-card:hover .mascota-image {
        transform: scale(1.05);
    }

    .mascota-image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 80px;
        background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%);
    }

    .mascota-badge-disponible {
        position: absolute;
        top: 16px;
        right: 16px;
        background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-family: 'Nunito', sans-serif;
        font-size: 13px;
        font-weight: 700;
    }

    .mascota-info {
        padding: 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .mascota-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .mascota-header h3 {
        font-family: 'Nunito', sans-serif;
        font-size: 22px;
        font-weight: 700;
        color: #000;
        margin: 0;
    }

    .mascota-tag {
        background: #FFD4E5;
        color: #C25B8A;
        padding: 4px 12px;
        border-radius: 12px;
        font-family: 'Nunito', sans-serif;
        font-size: 13px;
        font-weight: 600;
    }

    .mascota-tag.gato {
        background: #E8D4FF;
        color: #8A5BC2;
    }

    .mascota-tag.perro {
        background: #D4E5FF;
        color: #4A7BC2;
    }

    .mascota-tag.otro {
        background: #FFF4D4;
        color: #C2A35B;
    }

    .mascota-raza {
        font-family: 'Nunito', sans-serif;
        color: #666;
        font-size: 15px;
        margin: 0 0 4px 0;
    }

    .mascota-edad {
        font-family: 'Nunito', sans-serif;
        color: #999;
        font-size: 14px;
        margin: 0 0 12px 0;
    }

    .mascota-descripcion {
        font-family: 'Nunito', sans-serif;
        color: #666;
        font-size: 14px;
        font-style: italic;
        line-height: 1.5;
        margin: 0 0 12px 0;
        flex: 1;
    }

    .mascota-ubicacion {
        font-family: 'Nunito', sans-serif;
        color: #999;
        font-size: 13px;
        margin: 0 0 16px 0;
    }

    .mascota-buttons {
        display: flex;
        gap: 12px;
    }

    .btn-adoptar {
        flex: 1;
        background: linear-gradient(135deg, #BBFA8C 0%, #A5E88A 100%);
        color: #000;
        padding: 12px 16px;
        border-radius: 25px;
        text-decoration: none;
        font-family: 'Nunito', sans-serif;
        font-weight: 700;
        font-size: 14px;
        text-align: center;
        transition: transform 0.2s, box-shadow 0.3s;
    }

    .btn-adoptar:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(187, 250, 140, 0.4);
        color: #000;
        text-decoration: none;
    }

    .btn-ver-mas {
        background: transparent;
        color: #666;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 25px;
        text-decoration: none;
        font-family: 'Nunito', sans-serif;
        font-weight: 700;
        font-size: 14px;
        text-align: center;
        transition: border-color 0.3s, color 0.3s;
    }

    .btn-ver-mas:hover {
        border-color: #BBFA8C;
        color: #333;
        text-decoration: none;
    }

    /* No Mascotas */
    .no-mascotas {
        text-align: center;
        padding: 80px 20px;
        max-width: 500px;
        margin: 0 auto;
    }

    .no-mascotas-icon {
        font-size: 100px;
        margin-bottom: 24px;
    }

    .no-mascotas h3 {
        font-family: 'Nunito', sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: #333;
        margin: 0 0 12px 0;
    }

    .no-mascotas p {
        font-family: 'Nunito', sans-serif;
        font-size: 16px;
        color: #666;
        margin: 0 0 24px 0;
    }

    .btn-alternativo {
        background: #FAA88C;
        color: #000;
        padding: 14px 32px;
        border-radius: 25px;
        text-decoration: none;
        font-family: 'Nunito', sans-serif;
        font-weight: 700;
        font-size: 16px;
        display: inline-block;
        transition: transform 0.2s, box-shadow 0.3s;
    }

    .btn-alternativo:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(250, 168, 140, 0.4);
        color: #000;
        text-decoration: none;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .mascotas-hero h1 {
            font-size: 28px;
        }

        .mascotas-hero .subtitle {
            font-size: 16px;
        }

        .filtros-form {
            flex-direction: column;
            align-items: stretch;
        }

        .filtro-group {
            width: 100%;
        }

        .filtro-input, .filtro-select {
            width: 100%;
        }

        .filtro-buttons {
            justify-content: center;
        }

        .mascota-card {
            max-width: 100%;
        }

        .mascota-image-container {
            height: 220px;
        }
    }
</style>
