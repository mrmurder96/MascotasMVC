@model IEnumerable<Integrador.Models.Mascotas>
@{
    ViewBag.Title = "Reporte de Mascotas";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";

    var lista = Model?.ToList() ?? new List<Integrador.Models.Mascotas>();
    var totalMascotas = lista.Count;
    var disponibles = lista.Count(m => m.Estado == "Disponible");
    var adoptadas = lista.Count(m => m.Estado == "Adoptado");
    var enProceso = lista.Count(m => m.Estado == "En Proceso");

    var porTipo = lista.GroupBy(m => m.Tipo)
        .Select(g => new { Tipo = g.Key, Cantidad = g.Count(), Porcentaje = totalMascotas > 0 ? Math.Round((decimal)g.Count() / totalMascotas * 100, 1) : 0 })
        .OrderByDescending(x => x.Cantidad)
        .ToList();

    var edadPromedio = lista.Where(m => m.Edad.HasValue).Any() 
        ? Math.Round(lista.Where(m => m.Edad.HasValue).Average(m => m.Edad.Value), 1) 
        : 0;

    var cachorros = lista.Count(m => m.Edad.HasValue && m.Edad.Value <= 1);
    var jovenes = lista.Count(m => m.Edad.HasValue && m.Edad.Value > 1 && m.Edad.Value <= 3);
    var adultos = lista.Count(m => m.Edad.HasValue && m.Edad.Value > 3 && m.Edad.Value <= 7);
    var seniors = lista.Count(m => m.Edad.HasValue && m.Edad.Value > 7);
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="fas fa-paw me-2"></i>Reporte de Mascotas</h2>
            <p class="text-muted mb-0">Inventario y estadísticas de todas las mascotas registradas</p>
        </div>
        <div>
            <a href="@Url.Action("Mascotas", new { tipo = ViewBag.TipoSeleccionado, estado = ViewBag.EstadoSeleccionado, formato = "csv" })" 
               class="btn btn-success">
                <i class="fas fa-file-csv me-1"></i> Exportar CSV
            </a>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary ms-2">
                <i class="fas fa-arrow-left me-1"></i> Volver
            </a>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label"><i class="fas fa-tag me-1"></i>Tipo</label>
                    @if (ViewBag.Tipos != null)
                    {
                        @Html.DropDownList("tipo", (SelectList)ViewBag.Tipos, new { @class = "form-select" })
                    }
                    else
                    {
                        <select name="tipo" class="form-select">
                            <option value="">Todos</option>
                            <option value="Perro">Perro</option>
                            <option value="Gato">Gato</option>
                            <option value="Ave">Ave</option>
                            <option value="Otro">Otro</option>
                        </select>
                    }
                </div>
                <div class="col-md-4">
                    <label class="form-label"><i class="fas fa-filter me-1"></i>Estado</label>
                    @if (ViewBag.Estados != null)
                    {
                        @Html.DropDownList("estado", (SelectList)ViewBag.Estados, new { @class = "form-select" })
                    }
                    else
                    {
                        <select name="estado" class="form-select">
                            <option value="">Todos</option>
                            <option value="Disponible">Disponible</option>
                            <option value="Adoptado">Adoptado</option>
                            <option value="En Proceso">En Proceso</option>
                        </select>
                    }
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i> Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Total Mascotas</h6>
                            <h2 class="mb-0 fw-bold">@totalMascotas</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-paw fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Disponibles</h6>
                            <h2 class="mb-0 fw-bold">@disponibles</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-check-circle fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Adoptadas</h6>
                            <h2 class="mb-0 fw-bold">@adoptadas</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-home fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">En Proceso</h6>
                            <h2 class="mb-0 fw-bold">@enProceso</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-hourglass-half fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Estadísticas por Tipo y Edad -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2 text-primary"></i>Distribución por Tipo</h5>
                </div>
                <div class="card-body">
                    @foreach (var item in porTipo)
                    {
                        var iconoClass = "fa-paw";
                        var colorClass = "primary";
                        switch (item.Tipo)
                        {
                            case "Perro": iconoClass = "fa-dog"; colorClass = "warning"; break;
                            case "Gato": iconoClass = "fa-cat"; colorClass = "info"; break;
                            case "Ave": iconoClass = "fa-dove"; colorClass = "success"; break;
                            case "Conejo": iconoClass = "fa-carrot"; colorClass = "danger"; break;
                            case "Roedor": iconoClass = "fa-otter"; colorClass = "secondary"; break;
                        }
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span><i class="fas @iconoClass me-2 text-@colorClass"></i>@item.Tipo</span>
                                <span class="text-muted">@item.Cantidad (@item.Porcentaje%)</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-@colorClass" style="width: @item.Porcentaje%"></div>
                            </div>
                        </div>
                    }
                    @if (!porTipo.Any())
                    {
                        <p class="text-muted text-center">No hay datos disponibles</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-birthday-cake me-2 text-info"></i>Información de Edad</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <h1 class="display-4 fw-bold text-success">@edadPromedio</h1>
                        <p class="text-muted">Edad Promedio (años)</p>
                    </div>
                    <hr />
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <span><i class="fas fa-baby text-primary me-2"></i>Cachorros (0-1 año)</span>
                            <strong class="text-primary">@cachorros</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span><i class="fas fa-dog text-success me-2"></i>Jóvenes (1-3 años)</span>
                            <strong class="text-success">@jovenes</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span><i class="fas fa-paw text-info me-2"></i>Adultos (3-7 años)</span>
                            <strong class="text-info">@adultos</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span><i class="fas fa-heart text-secondary me-2"></i>Seniors (+7 años)</span>
                            <strong class="text-secondary">@seniors</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Datos -->
    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-table me-2 text-primary"></i>Listado de Mascotas</h5>
            <span class="badge bg-secondary">@totalMascotas registros</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Raza</th>
                            <th>Edad</th>
                            <th>Sexo</th>
                            <th>Ubicación</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (lista.Any())
                        {
                            foreach (var mascota in lista)
                            {
                                var labelClass = "secondary";
                                switch (mascota.Estado)
                                {
                                    case "Disponible": labelClass = "success"; break;
                                    case "Adoptado": labelClass = "info"; break;
                                    case "En Proceso": labelClass = "warning"; break;
                                    case "No Disponible": labelClass = "danger"; break;
                                }
                                <tr>
                                    <td><span class="badge bg-dark">@mascota.Id</span></td>
                                    <td>
                                        <i class="fas @mascota.IconoTipoClass me-1 text-success"></i>
                                        <strong>@mascota.Nombre</strong>
                                    </td>
                                    <td>@mascota.Tipo</td>
                                    <td>@(mascota.Raza ?? "Mestizo")</td>
                                    <td>@(mascota.Edad.HasValue ? mascota.Edad.Value + " años" : "N/A")</td>
                                    <td>@mascota.Sexo</td>
                                    <td><small>@mascota.Ubicacion</small></td>
                                    <td><span class="badge bg-@labelClass">@mascota.Estado</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4">
                                    <i class="fas fa-paw fa-3x text-muted mb-3 d-block"></i>
                                    <p class="text-muted mb-0">No hay mascotas con los filtros seleccionados</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
