@model Integrador.Models.Adopciones
@{
    ViewBag.Title = "Seguimientos de Adopción";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="glyphicon glyphicon-list-alt"></i> Seguimientos Post-Adopción</h2>
        </div>
        <div class="col-md-4 text-right">
            <a href="@Url.Action("Create", new { adopcionId = Model.Id })" class="btn btn-success">
                <i class="glyphicon glyphicon-plus"></i> Nuevo Seguimiento
            </a>
        </div>
    </div>

    @Html.Partial("_AlertMessages")

    <!-- Información de la Adopción -->
    <div class="row">
        <div class="col-md-6">
            <div class="panel panel-info">
                <div class="panel-heading">
                    <h4>Información de la Adopción #@Model.Id</h4>
                </div>
                <div class="panel-body">
                    <dl class="dl-horizontal">
                        <dt>Solicitante</dt>
                        <dd><strong>@Model.NombreSolicitante</strong></dd>
                        <dt>Email</dt>
                        <dd>@Model.Email</dd>
                        <dt>Teléfono</dt>
                        <dd>@Model.Telefono</dd>
                        <dt>Fecha Solicitud</dt>
                        <dd>@Model.FechaSolicitud.ToString("dd/MM/yyyy")</dd>
                        <dt>Estado</dt>
                        <dd><span class="label label-success">@Model.Estado</span></dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            @if (Model.Mascotas != null)
            {
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4>Mascota: @Model.Mascotas.Nombre</h4>
                    </div>
                    <div class="panel-body">
                        <dl class="dl-horizontal">
                            <dt>Tipo</dt>
                            <dd>@Model.Mascotas.Tipo</dd>
                            <dt>Edad</dt>
                            <dd>@(Model.Mascotas.Edad.HasValue ? Model.Mascotas.Edad + " años" : "No especificada")</dd>
                            <dt>Ubicación</dt>
                            <dd>@Model.Mascotas.Ubicacion</dd>
                        </dl>
                        @if (!string.IsNullOrEmpty(Model.Mascotas.FotoUrl))
                        {
                            <div class="text-center">
                                <img src="@Url.Content(Model.Mascotas.FotoUrl)" alt="@Model.Mascotas.Nombre" class="img-thumbnail" style="max-width: 150px;" />
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Lista de Seguimientos -->
    <div class="panel panel-default">
        <div class="panel-heading">
            <h4>Historial de Seguimientos</h4>
        </div>
        <div class="panel-body">
            @{
                var seguimientos = ViewBag.Seguimientos as List<Integrador.Models.Seguimientos>;
            }
            @if (seguimientos != null && seguimientos.Any())
            {
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Estado Mascota</th>
                            <th>Observaciones</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var seg in seguimientos)
                        {
                            var estadoClass = "default";
                            switch (seg.EstadoMascota)
                            {
                                case "Excelente": estadoClass = "success"; break;
                                case "Bueno": estadoClass = "info"; break;
                                case "Regular": estadoClass = "warning"; break;
                                default: estadoClass = "danger"; break;
                            }
                            <tr>
                                <td>@seg.Id</td>
                                <td>@seg.FechaSeguimiento.ToString("dd/MM/yyyy")</td>
                                <td>@seg.TipoSeguimiento</td>
                                <td><span class="label label-@estadoClass">@seg.EstadoMascota</span></td>
                                <td>@(seg.Observaciones != null && seg.Observaciones.Length > 80 ? seg.Observaciones.Substring(0, 77) + "..." : seg.Observaciones)</td>
                                <td>
                                    <div class="btn-group">
                                        <a href="@Url.Action("Edit", new { id = seg.Id })" class="btn btn-warning btn-xs" title="Editar">
                                            <i class="glyphicon glyphicon-edit"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", new { id = seg.Id })" class="btn btn-danger btn-xs" title="Eliminar"
                                           onclick="return confirm('¿Eliminar seguimiento?')">
                                            <i class="glyphicon glyphicon-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <h4>No hay seguimientos registrados para esta adopción</h4>
                    <p>Haga clic en "Nuevo Seguimiento" para registrar el primero.</p>
                </div>
            }
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <a href="@Url.Action("Index")" class="btn btn-default">
                <i class="glyphicon glyphicon-arrow-left"></i> Volver al Listado
            </a>
        </div>
    </div>
</div>

<style>
    .mb-4 { margin-bottom: 20px; }
    .table th { background-color: #BBFA8C; color: #000; font-weight: 600; }
    .panel-info > .panel-heading { background-color: #8CFAA4; color: #000; border-color: #93A597; }
</style>
