@model IEnumerable<Integrador.Models.Centro>
@using System.Web.Helpers

@{
    ViewBag.Title = "Centros de adopción";
    var apiKey = ViewBag.GoogleMapsApiKey ?? "";
    var centersJson = Html.Raw(Json.Encode(Model));
}

<main class="container mt-4" role="main" aria-label="Centros de adopción disponibles">
    <div class="row">
        <div class="col-md-4">
            <h1 style="font-size: 20px;">Centros</h1>

            @if (TempData["CentrosError"] != null)
            {
                <div class="alert alert-danger" role="alert" aria-live="assertive">@TempData["CentrosError"]</div>
            }

            @if (!Model.Any())
            {
                <div class="alert alert-info" role="status">No hay centros disponibles.</div>
            }
            else
            {
                <nav class="list-group" role="list" aria-label="Lista de centros de adopción">
                    @foreach (var c in Model)
                    {
                        <article class="list-group-item" role="listitem" aria-label="Centro @c.Nombre">
                            <h2 class="mb-1" style="font-size: 16px;">@c.Nombre</h2>
                            <p class="small mb-1" aria-label="Dirección: @c.Direccion">@c.Direccion</p>
                            <p class="small text-muted mb-1" aria-label="Teléfono: @c.Telefono">Tel: @c.Telefono</p>

                            @using (Html.BeginForm("SeleccionarCentro", "Ciudadano", FormMethod.Post, new { aria_label = "Seleccionar centro " + c.Nombre }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.Id" />
                                <button class="btn btn-sm btn-primary" type="submit" aria-label="Seleccionar @c.Nombre como centro de adopción">Seleccionar este centro</button>
                            }
                        </article>
                    }
                </nav>
            }
        </div>

        <div class="col-md-8">
            <h2 style="font-size: 20px;">Mapa</h2>
            <div id="map" style="width:100%;height:520px;border:1px solid #ddd;" role="application" aria-label="Mapa interactivo con ubicación de centros de adopción"></div>
        </div>
    </div>
</main>

@section scripts {
    <script>
        var centers = @centersJson;

        function initMap() {
            if (!centers || centers.length === 0) return;

            var first = centers[0];
            var map = new google.maps.Map(document.getElementById('map'), {
                center: { lat: parseFloat(first.Lat), lng: parseFloat(first.Lng) },
                zoom: 12
            });

            var bounds = new google.maps.LatLngBounds();

            centers.forEach(function (c) {
                var pos = { lat: parseFloat(c.Lat), lng: parseFloat(c.Lng) };
                var marker = new google.maps.Marker({
                    position: pos,
                    map: map,
                    title: c.Nombre
                });

                var info = new google.maps.InfoWindow({
                    content: '<div><strong>' + c.Nombre + '</strong><br/>' + c.Direccion + '<br/>Tel: ' + (c.Telefono || '') + '</div>'
                });

                marker.addListener('click', function () {
                    info.open(map, marker);
                });

                bounds.extend(pos);
            });

            map.fitBounds(bounds);
        }
    </script>

    @* Carga la API de Google Maps con tu API Key configurada en web.config appSettings: GoogleMapsApiKey *@
    <script async defer src="https://maps.googleapis.com/maps/api/js?key=@apiKey&callback=initMap"></script>
}

