

@{
    ViewBag.Title = Model?.Titulo ?? "Detalle campaóa";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-8">
            <img src="@(string.IsNullOrEmpty(Model.ImagenUrl) ? "/Content/placeholder_campaign.png" : Model.ImagenUrl)" class="img-fluid rounded shadow mb-3" alt="@Model.Titulo" />
            <h2 class="text-success">@Model.Titulo</h2>
            <p><strong>Inicio:</strong> @Model.FechaInicio.ToString("dd/MM/yyyy")</p>
            @if (Model.FechaFin.HasValue)
            {
                <p><strong>Fin:</strong> @Model.FechaFin.Value.ToString("dd/MM/yyyy")</p>
            }
            <hr />
            <p>@Html.Raw(Model.Descripcion)</p>

            <a href="@Url.Action("Index","Campanas")" class="btn btn-link">Volver a campaóas</a>
        </div>
    </div>
</div>