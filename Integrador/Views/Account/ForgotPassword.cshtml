@{
    ViewBag.Title = "Recuperar contraseńa";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow p-4" style="width:100%; max-width:480px;">
        <h3 class="text-center text-success mb-3">Recuperar contraseńa</h3>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">@Html.ValidationSummary(false)</div>
        }

        <p>Ingresa tu correo y te enviaremos una contraseńa temporal por email.</p>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-success">Enviar contraseńa temporal</button>
            </div>
        }

        <div class="text-center mt-3">
            <a href="@Url.Action("Login","Account")" class="text-muted">Volver al inicio de sesión</a>
        </div>
    </div>
</div>