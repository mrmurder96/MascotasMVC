

@using System.Linq

@{
    ViewBag.Title = "Mascotas disponibles";
}

<div class="container py-4" role="main">
    <header>
        <h1 class="text-success mb-4" tabindex="0">Mascotas disponibles para adopción</h1>
        <p class="lead" role="status" aria-live="polite">
            Se encontraron <strong>@Model.Count</strong> mascotas disponibles para adopción
        </p>
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="row" role="list" aria-label="Lista de mascotas disponibles">
            @foreach (var pet in Model)
            {
                <div class="col-md-4 mb-4" role="listitem">
                    <article class="card h-100 shadow-sm" aria-labelledby="mascota-@pet.Id-titulo">
                        @if (!string.IsNullOrEmpty(pet.FotoUrl))
                        {
                            <img src="@pet.FotoUrl" 
                                 class="card-img-top" 
                                 alt="Fotografóa de @pet.Nombre, @pet.Tipo de @pet.Edad aóos" 
                                 style="height:200px;object-fit:cover;"
                                 role="img" />
                        }
                        else
                        {
                            <img src="/Content/images/no-image.png" 
                                 class="card-img-top" 
                                 alt="Sin fotografóa disponible" 
                                 style="height:200px;object-fit:cover;background:#f0f0f0;"
                                 role="img" />
                        }
                        
                        <div class="card-body d-flex flex-column">
                            <h2 class="card-title h5" id="mascota-@pet.Id-titulo" tabindex="0">@pet.Nombre</h2>
                            
                            <dl class="mb-2">
                                <dt class="sr-only">Tipo de animal</dt>
                                <dd class="card-text mb-1">
                                    <span aria-hidden="true"><strong>Tipo:</strong></span>
                                    <span aria-label="Tipo de animal: @pet.Tipo">@pet.Tipo</span>
                                </dd>
                                
                                <dt class="sr-only">Edad</dt>
                                <dd class="card-text mb-1">
                                    <span aria-hidden="true"><strong>Edad:</strong></span>
                                    <span aria-label="Edad: @pet.Edad años">@pet.Edad años</span>
                                </dd>
                                
                                <dt class="sr-only">Ubicación</dt>
                                <dd class="card-text mb-2">
                                    <span aria-hidden="true"><strong>Ubicación:</strong></span>
                                    <span aria-label="Ubicación: @pet.Ubicacion">@pet.Ubicacion</span>
                                </dd>
                            </dl>
                            
                            <a class="mt-auto btn btn-outline-success" 
                               href="@Url.Action("Details","Mascotas", new { id = pet.Id })"
                               aria-label="Ver información detallada de @pet.Nombre">
                                Ver más detalles
                            </a>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert" aria-live="polite">
            <h3>No hay mascotas disponibles en este momento</h3>
            <p>Por favor, vuelve más tarde para ver nuevas mascotas en adopción.</p>
        </div>
    }
</div>

<style>
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap;
        border: 0;
    }
    
    .card:focus-within {
        box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.5) !important;
    }
    
    .card-title:focus {
        outline: 2px solid #28a745;
        outline-offset: 2px;
    }
</style>
