@{
    ViewBag.Title = "Reportes y Estadísticas";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";

    var totalMascotas = ViewBag.TotalMascotas ?? 0;
    var totalAdopciones = ViewBag.TotalAdopciones ?? 0;
    var solicitudesPendientes = ViewBag.SolicitudesPendientes ?? 0;
    var totalUsuarios = ViewBag.TotalUsuarios ?? 0;
}

<div class="container-fluid py-4">
    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="fas fa-chart-bar me-2"></i>Reportes y Estadísticas</h2>
            <p class="text-muted mb-0">Panel de control y análisis del sistema de adopciones</p>
        </div>
    </div>

    <!-- KPIs Principales -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #8CFAA4 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted mb-2">Mascotas Registradas</h6>
                            <h2 class="mb-0 fw-bold text-success">@totalMascotas</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-paw fa-2x text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #BBFA8C !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted mb-2">Adopciones Exitosas</h6>
                            <h2 class="mb-0 fw-bold text-primary">@totalAdopciones</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-home fa-2x text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #FAA88C !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted mb-2">Solicitudes Pendientes</h6>
                            <h2 class="mb-0 fw-bold text-warning">@solicitudesPendientes</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-clock fa-2x text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #93A597 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted mb-2">Usuarios Activos</h6>
                            <h2 class="mb-0 fw-bold text-info">@totalUsuarios</h2>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-users fa-2x text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Reportes Disponibles -->
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="fas fa-folder-open me-2 text-primary"></i>Reportes Disponibles</h5>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <!-- Reporte de Adopciones -->
                <div class="col-md-6">
                    <div class="border rounded p-4 h-100" style="border-left: 4px solid #BBFA8C !important;">
                        <div class="d-flex align-items-start">
                            <div class="bg-success bg-opacity-10 rounded p-3 me-3">
                                <i class="fas fa-file-alt fa-2x text-success"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-2">Reporte de Adopciones</h5>
                                <p class="text-muted mb-3">Listado completo de adopciones realizadas con filtros por fecha y estado</p>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Adopciones", "Reportes", new { area = "Admin" })" class="btn btn-primary btn-sm">
                                        <i class="fas fa-eye me-1"></i> Ver Reporte
                                    </a>
                                    <a href="@Url.Action("Adopciones", "Reportes", new { area = "Admin", formato = "csv" })" class="btn btn-success btn-sm">
                                        <i class="fas fa-file-csv me-1"></i> CSV
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reporte de Mascotas -->
                <div class="col-md-6">
                    <div class="border rounded p-4 h-100" style="border-left: 4px solid #8CFAA4 !important;">
                        <div class="d-flex align-items-start">
                            <div class="bg-info bg-opacity-10 rounded p-3 me-3">
                                <i class="fas fa-paw fa-2x text-info"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-2">Reporte de Mascotas</h5>
                                <p class="text-muted mb-3">Estadísticas de mascotas disponibles, adoptadas y en proceso</p>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Mascotas", "Reportes", new { area = "Admin" })" class="btn btn-primary btn-sm">
                                        <i class="fas fa-eye me-1"></i> Ver Reporte
                                    </a>
                                    <a href="@Url.Action("Mascotas", "Reportes", new { area = "Admin", formato = "csv" })" class="btn btn-success btn-sm">
                                        <i class="fas fa-file-csv me-1"></i> CSV
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reporte de Solicitudes -->
                <div class="col-md-6">
                    <div class="border rounded p-4 h-100" style="border-left: 4px solid #FAA88C !important;">
                        <div class="d-flex align-items-start">
                            <div class="bg-warning bg-opacity-10 rounded p-3 me-3">
                                <i class="fas fa-file-signature fa-2x text-warning"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-2">Reporte de Solicitudes</h5>
                                <p class="text-muted mb-3">Análisis de solicitudes por estado (pendientes, aprobadas, rechazadas)</p>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Solicitudes", "Reportes", new { area = "Admin" })" class="btn btn-primary btn-sm">
                                        <i class="fas fa-eye me-1"></i> Ver Reporte
                                    </a>
                                    <a href="@Url.Action("Solicitudes", "Reportes", new { area = "Admin", formato = "csv" })" class="btn btn-success btn-sm">
                                        <i class="fas fa-file-csv me-1"></i> CSV
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reporte de Usuarios -->
                <div class="col-md-6">
                    <div class="border rounded p-4 h-100" style="border-left: 4px solid #93A597 !important;">
                        <div class="d-flex align-items-start">
                            <div class="bg-secondary bg-opacity-10 rounded p-3 me-3">
                                <i class="fas fa-users fa-2x text-secondary"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-2">Reporte de Usuarios</h5>
                                <p class="text-muted mb-3">Listado de usuarios registrados y estadísticas de adopción por usuario</p>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Usuarios", "Reportes", new { area = "Admin" })" class="btn btn-primary btn-sm">
                                        <i class="fas fa-eye me-1"></i> Ver Reporte
                                    </a>
                                    <a href="@Url.Action("Usuarios", "Reportes", new { area = "Admin", formato = "csv" })" class="btn btn-success btn-sm">
                                        <i class="fas fa-file-csv me-1"></i> CSV
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Post-Seguimiento -->
                <div class="col-md-6">
                    <div class="border rounded p-4 h-100" style="border-left: 4px solid #0dcaf0 !important;">
                        <div class="d-flex align-items-start">
                            <div class="bg-info bg-opacity-10 rounded p-3 me-3">
                                <i class="fas fa-clipboard-check fa-2x text-info"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-2">Post-Seguimiento de Mascotas</h5>
                                <p class="text-muted mb-3">Control y seguimiento post-adopción de mascotas adoptadas</p>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("PostSeguimiento", "Reportes", new { area = "Admin" })" class="btn btn-primary btn-sm">
                                        <i class="fas fa-eye me-1"></i> Ver Reporte
                                    </a>
                                    <a href="@Url.Action("PostSeguimiento", "Reportes", new { area = "Admin", formato = "csv" })" class="btn btn-success btn-sm">
                                        <i class="fas fa-file-csv me-1"></i> CSV
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Auditoría de Seguridad -->
                <div class="col-md-6">
                    <div class="border rounded p-4 h-100" style="border-left: 4px solid #dc3545 !important;">
                        <div class="d-flex align-items-start">
                            <div class="bg-danger bg-opacity-10 rounded p-3 me-3">
                                <i class="fas fa-shield-alt fa-2x text-danger"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-2">Auditoría de Seguridad</h5>
                                <p class="text-muted mb-3">Registro de intentos fallidos de login y usuarios bloqueados</p>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Auditoria", "Reportes", new { area = "Admin" })" class="btn btn-primary btn-sm">
                                        <i class="fas fa-eye me-1"></i> Ver Reporte
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
