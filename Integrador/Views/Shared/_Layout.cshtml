<!DOCTYPE html>
<html lang="es">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Pura Compañía</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Nunito:wght@400;600;700;800;900&family=Nunito+Sans:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Nunito', sans-serif;
            color: #333;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Accesibilidad - Skip Link */
        .skip-link {
            position: absolute;
            top: -40px;
            left: 0;
            background: #000;
            color: #fff;
            padding: 8px 16px;
            text-decoration: none;
            z-index: 100;
            border-radius: 0 0 8px 0;
            font-weight: bold;
        }

        .skip-link:focus {
            top: 0;
        }

        /* Screen reader only */
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border-width: 0;
        }

        /* Live region for announcements */
        .sr-announcements {
            position: absolute;
            left: -10000px;
            width: 1px;
            height: 1px;
            overflow: hidden;
        }

        /* Navbar */
        .navbar {
            background-color: #FAA88C;
            width: 100%;
            height: 70px;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            box-shadow: 0px 2px 4px rgba(0,0,0,0.15);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-left: 0;
            color: #000;
            height: 70px;
        }

        .logo a {
            display: flex;
            align-items: center;
            gap: 12px;
            height: 100%;
            text-decoration: none;
            color: #000;
        }

        .logo a:hover {
            color: #000;
            text-decoration: none;
        }

        .logo img {
            width: 50px;
            height: 50px;
            object-fit: contain;
            display: block;
        }

        .logo span {
            font-family: 'Nunito Sans', sans-serif;
            font-weight: 700;
            font-size: 20px;
            font-style: italic;
            white-space: nowrap;
            line-height: 1;
        }

        .nav-links {
            display: flex;
            gap: 30px;
            align-items: center;
            list-style: none;
            margin: 0 20px 0 auto;
        }

        .nav-links a {
            text-decoration: none;
            color: #000;
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            font-size: 16px;
            transition: opacity 0.3s;
        }

        .nav-links a:hover {
            opacity: 0.7;
        }

        .btn-login {
            background-color: #BBFA8CB0;
            height: 44px;
            color: #000;
            padding: 0 24px;
            border-radius: 22px;
            text-decoration: none;
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            font-size: 15px;
            border: 2px solid #000000F7;
            transition: background-color 0.3s, transform 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            white-space: nowrap;
        }

        .btn-login:hover {
            background-color: #FA8C99;
            transform: scale(1.02);
        }

        /* Responsive */
        @@media (max-width: 1200px) {
            .navbar {
                padding: 0 30px;
            }

            .nav-links {
                gap: 25px;
                margin: 0 15px 0 auto;
            }

            .nav-links a {
                font-size: 15px;
            }

            .btn-login {
                font-size: 14px;
                padding: 0 20px;
                height: 42px;
            }
        }

        @@media (max-width: 992px) {
            .navbar {
                height: auto;
                padding: 15px 30px;
                flex-wrap: wrap;
            }

            .logo {
                height: auto;
            }

            .nav-links {
                width: 100%;
                justify-content: center;
                margin: 15px 0 0 0;
                gap: 20px;
            }

            .nav-links a {
                font-size: 15px;
            }

            .btn-login {
                margin-top: 15px;
            }
        }

        @@media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                padding: 15px 20px;
                gap: 15px;
            }

            .logo {
                height: auto;
            }

            .logo img {
                width: 45px;
                height: 45px;
            }

            .logo span {
                font-size: 18px;
            }

            .nav-links {
                flex-direction: column;
                gap: 12px;
                margin: 10px 0 0 0;
            }

            .nav-links a {
                font-size: 15px;
            }

            .btn-login {
                margin-top: 10px;
                font-size: 14px;
                padding: 0 20px;
                height: 40px;
            }
        }

        @@media (max-width: 480px) {
            .navbar {
                padding: 12px 15px;
            }

            .logo img {
                width: 40px;
                height: 40px;
            }

            .logo span {
                font-size: 16px;
            }

            .nav-links a {
                font-size: 14px;
            }

            .btn-login {
                font-size: 13px;
                height: 38px;
            }
        }
    </style>
</head>
<body>
    <!-- Skip Link para accesibilidad -->
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <!-- Región de anuncios para lectores de pantalla -->
    <div aria-live="polite" aria-atomic="true" class="sr-announcements" id="announcements"></div>

    <!-- Navbar -->
    <nav class="navbar" role="navigation" aria-label="Navegación principal">
        <div style="display: flex; align-items: center; width: 100%; gap: 20px;">
            <div class="logo">
                @if (Session["Nombre"] != null)
                {
                    <a href="@Url.Action("Index", "Ciudadano")">
                        <img src="https://via.placeholder.com/94x75/FAA88C/333?text=Logo" alt="Logo de Pura Compañía - Ir a página principal">
                        <span aria-label="Pura Compañía - Plataforma de adopción de mascotas">Pura Compañía</span>
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Index", "Home")">
                        <img src="https://via.placeholder.com/94x75/FAA88C/333?text=Logo" alt="Logo de Pura Compañía - Ir a página principal">
                        <span aria-label="Pura Compañía - Plataforma de adopción de mascotas">Pura Compañía</span>
                    </a>
                }
            </div>
            <ul class="nav-links" role="menubar">
                <li role="none"><a href="@Url.Action("Index", "Mascotas")" role="menuitem">Mascotas</a></li>
                <li role="none"><a href="@Url.Action("Soporte", "Home")" role="menuitem">Contacto</a></li>
            </ul>
            <div style="display: flex; align-items: center;">
                @if (Session["Nombre"] != null)
                {
                    <a href="@Url.Action("Perfil", "Ciudadano")" class="btn-login" aria-label="Ir a mi perfil de usuario">Mi Perfil</a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn-login" aria-label="Iniciar sesión en tu cuenta">Iniciar sesión</a>
                }
            </div>
        </div>
    </nav>

    <main id="main-content">
        @RenderBody()
    </main>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
