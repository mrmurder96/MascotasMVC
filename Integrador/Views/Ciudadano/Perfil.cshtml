@model Integrador.Models.ViewModels.PerfilViewModel

@{
    ViewBag.Title = "Mi perfil";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                <a href="@Url.Action("Index", "Ciudadano")" class="list-group-item list-group-item-action">Dashboard</a>
                <a href="@Url.Action("Perfil", "Ciudadano")" class="list-group-item list-group-item-action active">Mi Perfil</a>
                <a href="@Url.Action("Notificaciones", "Ciudadano")" class="list-group-item list-group-item-action">Notificaciones</a>
                <a href="@Url.Action("Imagenes", "Account")" class="list-group-item list-group-item-action">Mis Imágenes</a>
                <a href="@Url.Action("Logout", "Account")" class="list-group-item list-group-item-action">Cerrar sesión</a>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="card-title text-success">Mi Perfil</h4>

                    @if (TempData["PerfilSuccess"] != null)
                    {
                        <div class="alert alert-success">@TempData["PerfilSuccess"]</div>
                    }

                    @using (Html.BeginForm("Perfil", "Ciudadano", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-4 text-center">
                                <img src="@Url.Content(Model.FotoPerfilRuta ?? "/Content/images/default-avatar.png")" class="img-fluid rounded-circle mb-3" style="max-width:180px; border:1px solid #e6e6e6;" alt="Foto de perfil" />
                                <div>
                                    <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Imagenes", "Account")">Gestionar imágenes</a>
                                </div>

                                <div class="mt-3">
                                    <label class="form-label">Subir imágenes (JPG/PNG, máx 4MB, máx 5 archivos)</label>
                                    <input type="file" name="NuevasFotos" multiple accept=".jpg,.jpeg,.png,image/jpeg,image/png" class="form-control" />
                                    @Html.ValidationMessage("NuevasFotos", "", new { @class = "text-danger" })
                                    <small class="text-muted">Solo archivos JPG o PNG. Máximo 4 MB por archivo.</small>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.Nombres)
                                    @Html.TextBoxFor(m => m.Nombres, new { @class = "form-control", maxlength = "50" })
                                    @Html.ValidationMessageFor(m => m.Nombres, "", new { @class = "text-danger" })
                                </div>

                                <div class="mb-3">
                                    @Html.LabelFor(m => m.Apellidos)
                                    @Html.TextBoxFor(m => m.Apellidos, new { @class = "form-control", maxlength = "50" })
                                    @Html.ValidationMessageFor(m => m.Apellidos, "", new { @class = "text-danger" })
                                </div>

                                <div class="mb-3">
                                    @Html.LabelFor(m => m.Email)
                                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", maxlength = "150" })
                                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        @Html.LabelFor(m => m.Cedula)
                                        @Html.TextBoxFor(m => m.Cedula, new { @class = "form-control", maxlength = "10", placeholder = "Ej: 1712345678" })
                                        @Html.ValidationMessageFor(m => m.Cedula, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        @Html.LabelFor(m => m.Telefono)
                                        @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", maxlength = "15" })
                                        @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <div class="mb-3">
                                    @Html.LabelFor(m => m.Direccion)
                                    @Html.TextBoxFor(m => m.Direccion, new { @class = "form-control", maxlength = "250", placeholder = "Dirección de residencia" })
                                    @Html.ValidationMessageFor(m => m.Direccion, "", new { @class = "text-danger" })
                                </div>

                                <div class="mb-3">
                                    @Html.LabelFor(m => m.FechaNacimiento)
                                    @{
                                        var hoy = DateTime.Today;
                                        var maxFechaNac = hoy.AddYears(-18).ToString("yyyy-MM-dd");
                                        var minFechaNac = hoy.AddYears(-70).ToString("yyyy-MM-dd");
                                    }
                                    @Html.TextBoxFor(m => m.FechaNacimiento, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date", max = maxFechaNac, min = minFechaNac, aria_label = "Fecha de nacimiento (entre 18 y 70 años)" })
                                    @Html.ValidationMessageFor(m => m.FechaNacimiento, "", new { @class = "text-danger" })
                                </div>

                                <div class="mt-3">
                                    <button type="submit" class="btn btn-success">Guardar cambios</button>
                                    <a href="@Url.Action("Index", "Ciudadano")" class="btn btn-outline-secondary ms-2">Cancelar</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var input = document.querySelector('input[name="NuevasFotos"]');
        if (!input) return;

        var previewContainer = document.createElement('div');
        previewContainer.id = 'previewContainer';
        previewContainer.style.display = 'flex';
        previewContainer.style.flexWrap = 'wrap';
        previewContainer.style.gap = '8px';
        input.parentNode.insertBefore(previewContainer, input.nextSibling);

        input.addEventListener('change', function (e) {
            previewContainer.innerHTML = '';
            var files = e.target.files;
            var allowedTypes = ['image/jpeg', 'image/png'];
            var maxBytes = 2 * 1024 * 1024;

            for (var i = 0; i < files.length; i++) {
                (function (file) {
                    var item = document.createElement('div');
                    item.style.width = '100px';
                    item.style.height = '100px';
                    item.style.overflow = 'hidden';
                    item.style.border = '1px solid #ddd';
                    item.style.borderRadius = '6px';
                    item.style.display = 'flex';
                    item.style.alignItems = 'center';
                    item.style.justifyContent = 'center';
                    item.style.background = '#f8f9fa';

                    if (allowedTypes.indexOf(file.type) === -1) {
                        item.innerText = 'Tipo inválido';
                        previewContainer.appendChild(item);
                        return;
                    }

                    if (file.size > maxBytes) {
                        item.innerText = 'Mayor a 2MB';
                        previewContainer.appendChild(item);
                        return;
                    }

                    var reader = new FileReader();
                    reader.onload = function (ev) {
                        var img = document.createElement('img');
                        img.src = ev.target.result;
                        img.style.width = '100%';
                        img.style.height = '100%';
                        img.style.objectFit = 'cover';
                        item.appendChild(img);
                    };
                    reader.readAsDataURL(file);
                    previewContainer.appendChild(item);
                })(files[i]);
            }
        });
    })();
</script>

