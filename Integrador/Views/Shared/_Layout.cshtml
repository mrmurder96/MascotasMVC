<!DOCTYPE html>
<html lang="es">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Pura Compañía</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Nunito:wght@400;600;700;800;900&family=Nunito+Sans:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <!-- Font Awesome para iconos modernos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        /* ===== GLYPHICONS COMPATIBILITY (Bootstrap 5 no incluye Glyphicons) ===== */
        /* Mapeo de Glyphicons a Font Awesome para compatibilidad */
        .glyphicon { font-family: 'Font Awesome 6 Free'; font-weight: 900; font-style: normal; display: inline-block; }
        .glyphicon-ok::before { content: "\f00c"; }
        .glyphicon-remove::before { content: "\f00d"; }
        .glyphicon-trash::before { content: "\f1f8"; }
        .glyphicon-edit::before { content: "\f304"; }
        .glyphicon-pencil::before { content: "\f303"; }
        .glyphicon-eye-open::before { content: "\f06e"; }
        .glyphicon-eye-close::before { content: "\f070"; }
        .glyphicon-search::before { content: "\f002"; }
        .glyphicon-plus::before { content: "\2b"; }
        .glyphicon-minus::before { content: "\f068"; }
        .glyphicon-refresh::before { content: "\f021"; }
        .glyphicon-home::before { content: "\f015"; }
        .glyphicon-user::before { content: "\f007"; }
        .glyphicon-cog::before { content: "\f013"; }
        .glyphicon-heart::before { content: "\f004"; }
        .glyphicon-star::before { content: "\f005"; }
        .glyphicon-list::before { content: "\f03a"; }
        .glyphicon-list-alt::before { content: "\f022"; }
        .glyphicon-file::before { content: "\f15b"; }
        .glyphicon-folder-open::before { content: "\f07c"; }
        .glyphicon-download::before { content: "\f019"; }
        .glyphicon-upload::before { content: "\f093"; }
        .glyphicon-envelope::before { content: "\f0e0"; }
        .glyphicon-phone::before { content: "\f095"; }
        .glyphicon-calendar::before { content: "\f073"; }
        .glyphicon-time::before { content: "\f017"; }
        .glyphicon-check::before { content: "\f058"; }
        .glyphicon-lock::before { content: "\f023"; }
        .glyphicon-warning-sign::before { content: "\f071"; }
        .glyphicon-info-sign::before { content: "\f05a"; }
        .glyphicon-question-sign::before { content: "\f059"; }
        .glyphicon-exclamation-sign::before { content: "\f06a"; }
        .glyphicon-arrow-left::before { content: "\f060"; }
        .glyphicon-arrow-right::before { content: "\f061"; }
        .glyphicon-arrow-up::before { content: "\f062"; }
        .glyphicon-arrow-down::before { content: "\f063"; }
        .glyphicon-chevron-left::before { content: "\f053"; }
        .glyphicon-chevron-right::before { content: "\f054"; }
        .glyphicon-chevron-up::before { content: "\f077"; }
        .glyphicon-chevron-down::before { content: "\f078"; }
        .glyphicon-th-list::before { content: "\f00b"; }
        .glyphicon-th::before { content: "\f00a"; }
        .glyphicon-ban-circle::before { content: "\f05e"; }
        .glyphicon-pause::before { content: "\f04c"; }
        .glyphicon-play::before { content: "\f04b"; }
        .glyphicon-stop::before { content: "\f04d"; }
        .glyphicon-floppy-disk::before { content: "\f0c7"; }
        .glyphicon-save::before { content: "\f0c7"; }
        .glyphicon-print::before { content: "\f02f"; }
        .glyphicon-camera::before { content: "\f030"; }
        .glyphicon-picture::before { content: "\f03e"; }
        .glyphicon-map-marker::before { content: "\f3c5"; }
        .glyphicon-comment::before { content: "\f075"; }
        .glyphicon-tags::before { content: "\f02c"; }
        .glyphicon-tag::before { content: "\f02b"; }
        .glyphicon-bookmark::before { content: "\f02e"; }
        .glyphicon-log-out::before { content: "\f2f5"; }
        .glyphicon-log-in::before { content: "\f2f6"; }
        .glyphicon-send::before { content: "\f1d8"; }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Nunito', sans-serif;
            color: #333;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Accesibilidad - Skip Link */
        .skip-link {
            position: absolute;
            top: -40px;
            left: 0;
            background: #000;
            color: #fff;
            padding: 8px 16px;
            text-decoration: none;
            z-index: 100;
            border-radius: 0 0 8px 0;
            font-weight: bold;
        }

        .skip-link:focus {
            top: 0;
        }

        /* Screen reader only */
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border-width: 0;
        }

        /* Live region for announcements */
        .sr-announcements {
            position: absolute;
            left: -10000px;
            width: 1px;
            height: 1px;
            overflow: hidden;
        }

        /* Navbar */
        .navbar {
            background-color: #FAA88C;
            width: 100%;
            height: 70px;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            box-shadow: 0px 2px 4px rgba(0,0,0,0.15);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-left: 0;
            color: #000;
            height: 70px;
        }

        .logo a {
            display: flex;
            align-items: center;
            gap: 12px;
            height: 100%;
            text-decoration: none;
            color: #000;
        }

        .logo a:hover {
            color: #000;
            text-decoration: none;
        }

        .logo img {
            width: 50px;
            height: 50px;
            object-fit: contain;
            display: block;
        }

        .logo span {
            font-family: 'Nunito Sans', sans-serif;
            font-weight: 700;
            font-size: 20px;
            font-style: italic;
            white-space: nowrap;
            line-height: 1;
        }

        .nav-links {
            display: flex;
            gap: 30px;
            align-items: center;
            list-style: none;
            margin: 0 20px 0 auto;
        }

        .nav-links a {
            text-decoration: none;
            color: #000;
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            font-size: 16px;
            transition: opacity 0.3s;
        }

        .nav-links a:hover {
            opacity: 0.7;
        }

        .btn-login {
            background-color: #BBFA8CB0;
            height: 44px;
            color: #000;
            padding: 0 24px;
            border-radius: 22px;
            text-decoration: none;
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            font-size: 15px;
            border: 2px solid #000000F7;
            transition: background-color 0.3s, transform 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            white-space: nowrap;
        }

        .btn-login:hover {
            background-color: #FA8C99;
            transform: scale(1.02);
        }

        /* Responsive */
        @@media (max-width: 1200px) {
            .navbar {
                padding: 0 30px;
            }

            .nav-links {
                gap: 25px;
                margin: 0 15px 0 auto;
            }

            .nav-links a {
                font-size: 15px;
            }

            .btn-login {
                font-size: 14px;
                padding: 0 20px;
                height: 42px;
            }
        }

        @@media (max-width: 992px) {
            .navbar {
                height: auto;
                padding: 15px 30px;
                flex-wrap: wrap;
            }

            .logo {
                height: auto;
            }

            .nav-links {
                width: 100%;
                justify-content: center;
                margin: 15px 0 0 0;
                gap: 20px;
            }

            .nav-links a {
                font-size: 15px;
            }

            .btn-login {
                margin-top: 15px;
            }
        }

        @@media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                padding: 15px 20px;
                gap: 15px;
            }

            .logo {
                height: auto;
            }

            .logo img {
                width: 45px;
                height: 45px;
            }

            .logo span {
                font-size: 18px;
            }

            .nav-links {
                flex-direction: column;
                gap: 12px;
                margin: 10px 0 0 0;
            }

            .nav-links a {
                font-size: 15px;
            }

            .btn-login {
                margin-top: 10px;
                font-size: 14px;
                padding: 0 20px;
                height: 40px;
            }
        }

        @@media (max-width: 480px) {
            .navbar {
                padding: 12px 15px;
            }

            .logo img {
                width: 40px;
                height: 40px;
            }

            .logo span {
                font-size: 16px;
            }

            .nav-links a {
                font-size: 14px;
            }

            .btn-login {
                font-size: 13px;
                height: 38px;
            }
        }
    </style>
</head>
<body>
    <!-- Skip Link para accesibilidad (NVDA compatible) -->
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <!-- Región de anuncios para lectores de pantalla -->
    <div aria-live="polite" aria-atomic="true" class="sr-announcements" id="announcements" role="status"></div>

    <!-- Navbar - Header principal de la aplicación -->
    <header role="banner">
        <nav class="navbar" role="navigation" aria-label="Navegación principal">
            <div style="display: flex; align-items: center; width: 100%; gap: 20px;">
                <div class="logo">
                    @if (Session["Nombre"] != null)
                    {
                        <a href="@Url.Action("Index", "Ciudadano")" aria-label="Pura Compañía - Plataforma de adopción de mascotas - Ir a página de inicio">
                            <img src="@Url.Content("~/Content/images/logo.png")" alt="Logo de Pura Compañía">
                            <span>Pura Compañía</span>
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Landing", "Home")" aria-label="Pura Compañía - Plataforma de adopción de mascotas - Ir a página de inicio">
                            <img src="@Url.Content("~/Content/images/logo.png")" alt="Logo de Pura Compañía">
                            <span>Pura Compañía</span>
                        </a>
                    }
                </div>
                <ul class="nav-links" role="menubar">
                    <li role="none">
                        <a href="@Url.Action("Index", "Mascotas")" role="menuitem" aria-label="Ver catálogo de mascotas disponibles para adopción">Mascotas</a>
                    </li>
                    <li role="none">
                        <a href="@Url.Action("Soporte", "Home")" role="menuitem" aria-label="Contactarnos - Enviar mensaje o solicitar información">Contacto</a>
                    </li>
                </ul>
                <div style="display: flex; align-items: center;">
                    @if (Session["Nombre"] != null)
                    {
                        <a href="@Url.Action("Perfil", "Ciudadano")" class="btn-login" aria-label="Ir a mi perfil de usuario @Session["Nombre"]">Mi Perfil</a>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn-login" aria-label="Iniciar sesión en tu cuenta">Iniciar sesión</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <!-- Contenido principal de la página -->
    <main id="main-content" role="main">
        @RenderBody()
    </main>

    <!-- Footer - Información de la aplicación -->
    <footer role="contentinfo" aria-label="Información de pie de página de Pura Compañía">
        <div class="sr-only">Fin del contenido principal</div>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
