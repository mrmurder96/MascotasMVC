@model IEnumerable<Integrador.Models.Adopciones>
@{
    ViewBag.Title = "Reporte de Solicitudes";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";

    var lista = Model?.ToList() ?? new List<Integrador.Models.Adopciones>();
    var total = lista.Count;
    var pendientes = lista.Count(s => s.Estado == "Pendiente" || s.Estado == "En Revisión" || s.Estado == "En Proceso");
    var aprobadas = lista.Count(s => s.Estado == "Aprobada" || s.Estado == "Completada");
    var rechazadas = lista.Count(s => s.Estado == "Rechazada");
    var canceladas = lista.Count(s => s.Estado == "Cancelada");
    var tiempoPromedio = ViewBag.TiempoPromedioAprobacion ?? 0;
    var tasaAprobacion = total > 0 ? Math.Round((decimal)aprobadas / total * 100, 1) : 0;

    var porEstado = lista.GroupBy(s => s.Estado)
        .Select(g => new { Estado = g.Key, Cantidad = g.Count(), Porcentaje = total > 0 ? Math.Round((decimal)g.Count() / total * 100, 1) : 0 })
        .OrderByDescending(x => x.Cantidad)
        .ToList();
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="fas fa-file-alt me-2"></i>Reporte de Solicitudes</h2>
            <p class="text-muted mb-0">Análisis de solicitudes de adopción por estado y período</p>
        </div>
        <div>
            <a href="@Url.Action("Solicitudes", new { fechaDesde = ViewBag.FechaDesde, fechaHasta = ViewBag.FechaHasta, estado = ViewBag.EstadoSeleccionado, formato = "csv" })" 
               class="btn btn-success">
                <i class="fas fa-file-csv me-1"></i> Exportar CSV
            </a>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary ms-2">
                <i class="fas fa-arrow-left me-1"></i> Volver
            </a>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label"><i class="fas fa-calendar me-1"></i>Desde</label>
                    <input type="date" name="fechaDesde" class="form-control" 
                           value="@(ViewBag.FechaDesde != null ? ((DateTime)ViewBag.FechaDesde).ToString("yyyy-MM-dd") : "")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label"><i class="fas fa-calendar-alt me-1"></i>Hasta</label>
                    <input type="date" name="fechaHasta" class="form-control" 
                           value="@(ViewBag.FechaHasta != null ? ((DateTime)ViewBag.FechaHasta).ToString("yyyy-MM-dd") : "")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label"><i class="fas fa-filter me-1"></i>Estado</label>
                    @if (ViewBag.Estados != null)
                    {
                        @Html.DropDownList("estado", (SelectList)ViewBag.Estados, new { @class = "form-select" })
                    }
                    else
                    {
                        <select name="estado" class="form-select">
                            <option value="">Todos</option>
                        </select>
                    }
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i> Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Pendientes</h6>
                            <h2 class="mb-0 fw-bold">@pendientes</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-clock fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Aprobadas</h6>
                            <h2 class="mb-0 fw-bold">@aprobadas</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-check-circle fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Rechazadas</h6>
                            <h2 class="mb-0 fw-bold">@rechazadas</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-times-circle fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Tiempo Promedio</h6>
                            <h2 class="mb-0 fw-bold">@tiempoPromedio días</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-stopwatch fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Distribución y Resumen -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2 text-primary"></i>Distribución por Estado</h5>
                </div>
                <div class="card-body">
                    @foreach (var item in porEstado)
                    {
                        var colorClass = "secondary";
                        switch (item.Estado)
                        {
                            case "Aprobada":
                            case "Completada":
                            case "Finalizada":
                                colorClass = "success";
                                break;
                            case "Pendiente":
                            case "En Revisión":
                            case "En Proceso":
                                colorClass = "warning";
                                break;
                            case "Rechazada":
                            case "Cancelada":
                                colorClass = "danger";
                                break;
                        }
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="badge bg-@colorClass">@item.Estado</span>
                                <span class="text-muted">@item.Cantidad (@item.Porcentaje%)</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-@colorClass" style="width: @item.Porcentaje%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2 text-info"></i>Resumen del Período</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Período analizado:</span>
                            <strong>
                                @(ViewBag.FechaDesde != null ? ((DateTime)ViewBag.FechaDesde).ToString("dd/MM/yyyy") : "N/A")
                                - @(ViewBag.FechaHasta != null ? ((DateTime)ViewBag.FechaHasta).ToString("dd/MM/yyyy") : "N/A")
                            </strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Total de solicitudes:</span>
                            <strong class="text-primary">@total</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Tasa de aprobación:</span>
                            <strong class="text-success">@tasaAprobacion%</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Tiempo promedio:</span>
                            <strong>@tiempoPromedio días</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Datos -->
    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-table me-2 text-primary"></i>Detalle de Solicitudes</h5>
            <span class="badge bg-secondary">@total registros</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Fecha</th>
                            <th>Mascota</th>
                            <th>Solicitante</th>
                            <th>Email</th>
                            <th>Estado</th>
                            <th class="text-center">Días</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (lista.Any())
                        {
                            foreach (var solicitud in lista)
                            {
                                var labelClass = "secondary";
                                switch (solicitud.Estado)
                                {
                                    case "Aprobada":
                                    case "Completada":
                                    case "Finalizada":
                                        labelClass = "success";
                                        break;
                                    case "Pendiente":
                                    case "En Revisión":
                                    case "En Proceso":
                                        labelClass = "warning";
                                        break;
                                    case "Rechazada":
                                    case "Cancelada":
                                        labelClass = "danger";
                                        break;
                                }
                                var dias = (DateTime.Now - solicitud.FechaSolicitud).Days;
                                <tr>
                                    <td><span class="badge bg-dark">@solicitud.Id</span></td>
                                    <td>@solicitud.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <strong>@(solicitud.Mascotas?.Nombre ?? "N/A")</strong>
                                    </td>
                                    <td>@solicitud.NombreSolicitante</td>
                                    <td><small>@solicitud.Email</small></td>
                                    <td><span class="badge bg-@labelClass">@solicitud.Estado</span></td>
                                    <td class="text-center">
                                        <span class="badge bg-@(dias > 30 ? "danger" : dias > 7 ? "warning" : "info") @(dias > 7 && dias <= 30 ? "text-dark" : "")">
                                            @dias
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4">
                                    <i class="fas fa-inbox fa-3x text-muted mb-3 d-block"></i>
                                    <p class="text-muted mb-0">No se encontraron solicitudes con los filtros seleccionados</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
