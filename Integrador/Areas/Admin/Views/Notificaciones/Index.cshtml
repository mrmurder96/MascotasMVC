@model IEnumerable<Integrador.Models.Notificaciones>
@{
    ViewBag.Title = "Gestiˇn de Notificaciones";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2><i class="fas fa-bell"></i> Gestiˇn de Notificaciones</h2>
        </div>
        <div class="col-md-6 text-right">
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="fas fa-plus"></i> Nueva Notificaciˇn
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            <strong>?</strong> @TempData["Success"]
        </div>
    }

    <div class="card">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Usuario</th>
                            <th>TÝtulo</th>
                            <th>Mensaje</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Usuarios.Nombres @item.Usuarios.Apellidos</td>
                                <td><strong>@item.Titulo</strong></td>
                                <td>@(item.Mensaje.Length > 50 ? item.Mensaje.Substring(0, 50) + "..." : item.Mensaje)</td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.Leido)
                                    {
                                        <span class="label label-success">LeÝdo</span>
                                    }
                                    else
                                    {
                                        <span class="label label-warning">No leÝdo</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-info btn-sm"><i class="fas fa-eye"></i></a>
                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                        <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No hay notificaciones registradas.
                </div>
            }
        </div>
    </div>
</div>
