@model Integrador.Models.Campanias
@{
    ViewBag.Title = "Detalles CampaŮa";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="container-fluid">
    <h2><i class="fas fa-bullhorn"></i> Detalles de la CampaŮa</h2>

    <div class="card">
        <div class="card-body">
            <dl class="dl-horizontal">
                <dt>ID</dt><dd>@Model.Id</dd>
                <dt>TŪtulo</dt><dd>@Model.Titulo</dd>
                <dt>Descripciůn</dt><dd>@Model.Descripcion</dd>
                <dt>Fecha Inicio</dt><dd>@Model.FechaInicio.ToString("dd/MM/yyyy")</dd>
                <dt>Fecha Fin</dt><dd>@(Model.FechaFin.HasValue ? Model.FechaFin.Value.ToString("dd/MM/yyyy") : "-")</dd>
                <dt>Imagen URL</dt><dd>@(Model.ImagenUrl ?? "-")</dd>
                <dt>Estado</dt><dd>@(Model.Activa ? "Activa" : "Inactiva")</dd>
            </dl>

            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning"><i class="fas fa-edit"></i> Editar</a>
            <a href="@Url.Action("Index")" class="btn btn-default">Volver</a>
        </div>
    </div>
</div>
