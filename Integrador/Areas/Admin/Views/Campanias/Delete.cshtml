@model Integrador.Models.Campanias
@{
    ViewBag.Title = "Eliminar Campaña";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="container-fluid">
    <h2 class="text-danger"><i class="fas fa-trash"></i> Eliminar Campaña</h2>

    <div class="alert alert-danger">
        <h4><i class="fas fa-exclamation-triangle"></i> ¿Está seguro de eliminar esta campaña?</h4>
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="dl-horizontal">
                <dt>Título</dt><dd>@Model.Titulo</dd>
                <dt>Descripción</dt><dd>@Model.Descripcion</dd>
                <dt>Fecha Inicio</dt><dd>@Model.FechaInicio.ToString("dd/MM/yyyy")</dd>
            </dl>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Confirmar</button>
                <a href="@Url.Action("Index")" class="btn btn-default">Cancelar</a>
            }
        </div>
    </div>
</div>
