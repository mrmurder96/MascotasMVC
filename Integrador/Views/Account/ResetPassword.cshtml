@{
    ViewBag.Title = "Cambiar contraseþa";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow p-4" style="width:100%; max-width:520px;">
        <h3 class="text-center text-success mb-3">Cambiar contraseþa</h3>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">@Html.ValidationSummary(false)</div>
        }

        <p>Introduce tu correo, la contraseþa temporal que recibiste por email y la nueva contraseþa.</p>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseþa temporal</label>
                <input type="password" name="temporaryPassword" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Nueva contraseþa</label>
                <input type="password" name="newPassword" class="form-control" required minlength="6" />
            </div>

            <div class="mb-3">
                <label class="form-label">Confirmar nueva contraseþa</label>
                <input type="password" name="confirmPassword" class="form-control" required minlength="6" />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-success">Actualizar contraseþa</button>
            </div>
        }

        <div class="text-center mt-3">
            <a href="@Url.Action("Login","Account")" class="text-muted">Volver al inicio de sesiµn</a>
        </div>
    </div>
</div>