<!DOCTYPE html>
<html lang="es">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Pura Compañía</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Nunito:wght@400;600;700;800;900&family=Nunito+Sans:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Nunito', sans-serif;
            color: #333;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Accesibilidad - Skip Link */
        .skip-link {
            position: absolute;
            top: -40px;
            left: 0;
            background: #000;
            color: #fff;
            padding: 8px 16px;
            text-decoration: none;
            z-index: 100;
            border-radius: 0 0 8px 0;
            font-weight: bold;
        }

        .skip-link:focus {
            top: 0;
        }

        /* Screen reader only */
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border-width: 0;
        }

        /* Live region for announcements */
        .sr-announcements {
            position: absolute;
            left: -10000px;
            width: 1px;
            height: 1px;
            overflow: hidden;
        }

        /* Navbar */
        .navbar {
            background-color: #FAA88C;
            width: 100%;
            height: 82px;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.25);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-left: 77px;
            color: #000;
        }

        .logo img {
            width: 94px;
            height: 75px;
            object-fit: contain;
        }

        .logo span {
            font-family: 'Nunito Sans', sans-serif;
            font-weight: 700;
            font-size: 24px;
            font-style: italic;
        }

        .logo a {
            display: flex;
            align-items: center;
            gap: 20px;
            text-decoration: none;
            color: #000;
        }

        .logo a:hover {
            color: #000;
            text-decoration: none;
        }

        .nav-links {
            display: flex;
            gap: 20px;
            align-items: center;
            list-style: none;
            margin-right: 40px;
            margin-left: auto;
        }

        .nav-links a {
            text-decoration: none;
            color: #000;
            font-family: 'Nunito', sans-serif;
            font-weight: 900;
            font-size: 24px;
            transition: opacity 0.3s;
        }

        .nav-links a:hover {
            opacity: 0.7;
        }

        .btn-login {
            background-color: #BBFA8CB0;
            height: 53px;
            max-width: 230px;
            color: #000;
            padding: 5px 34px;
            border-radius: 30px;
            text-decoration: none;
            font-family: 'Nunito', sans-serif;
            font-weight: 900;
            font-size: 24px;
            border: 2px solid #000000F7;
            transition: background-color 0.3s, transform 0.2s;
            margin-right: 20px;
            display: inline-block;
        }

        .btn-login:hover {
            background-color: #FA8C99;
            transform: scale(1.02);
        }

        /* Responsive */
        /* Específico para 1366x768 */
        @@media (max-width: 1400px) {
            .navbar { padding: 0 40px; height: 70px; }
            .logo img { width: 70px; height: 56px; }
            .logo span { font-size: 22px; }
            .nav-links { gap: 30px; }
            .nav-links a { font-size: 18px; }
            .btn-login { font-size: 18px; padding: 12px 26px; }
        }

        @@media (max-width: 1440px) {
            .navbar {
                padding: 0 60px;
            }

            .nav-links {
                margin-right: 40px;
            }
        }

        @@media (max-width: 1200px) {
            .nav-links {
                margin-right: 30px;
                gap: 30px;
            }

            .nav-links a {
                font-size: 20px;
            }

            .btn-login {
                font-size: 20px;
                padding: 15px 28px;
            }
        }

        @@media (max-width: 992px) {
            .navbar {
                flex-wrap: wrap;
                height: auto;
                padding: 20px 40px;
            }

            .logo {
                margin-left: 0;
            }

            .nav-links {
                margin-left: auto;
                margin-right: 0;
                width: 100%;
                justify-content: center;
                margin-top: 20px;
                gap: 20px;
            }

            .nav-links a {
                font-size: 18px;
            }

            .btn-login {
                margin-right: 0;
                margin-top: 20px;
            }
        }

        @@media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                height: auto;
                padding: 20px;
            }

            .logo {
                margin-left: 0;
            }

            .logo img {
                width: 60px;
                height: 48px;
            }

            .logo span {
                font-size: 20px;
            }

            .nav-links {
                flex-direction: column;
                gap: 15px;
                margin-left: 0;
                margin-top: 20px;
            }

            .nav-links a {
                font-size: 18px;
            }

            .btn-login {
                margin-right: 0;
                margin-top: 15px;
                font-size: 18px;
                padding: 12px 24px;
            }
        }
    </style>
</head>
<body>
<!-- Skip Link para accesibilidad -->
<a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    
<!-- Región de anuncios para lectores de pantalla -->
<div aria-live="polite" aria-atomic="true" class="sr-announcements" id="announcements"></div>
    
<!-- Navbar -->
    <nav class="navbar" role="navigation" aria-label="Navegación principal">
        <div class="logo">
            @if (Session["Nombre"] != null)
            {
                <a href="@Url.Action("Index", "Ciudadano")">
                    <img src="https://via.placeholder.com/94x75/FAA88C/333?text=Logo" alt="Logo de Pura Compañía - Ir a página principal">
                    <span aria-label="Pura Compañía - Plataforma de adopción de mascotas">Pura Compañía</span>
                </a>
            }
            else
            {
                <a href="@Url.Action("Index", "Home")">
                    <img src="https://via.placeholder.com/94x75/FAA88C/333?text=Logo" alt="Logo de Pura Compañía - Ir a página principal">
                    <span aria-label="Pura Compañía - Plataforma de adopción de mascotas">Pura Compañía</span>
                </a>
            }
        </div>
        <ul class="nav-links" role="menubar">
            <li role="none"><a href="@Url.Action("Index", "Mascotas")" role="menuitem">Mascotas</a></li>
            @if (Session["Nombre"] != null)
            {
                <li role="none"><a href="@Url.Action("Centros", "Ciudadano")" role="menuitem">Refugios</a></li>
            }
            <li role="none"><a href="@Url.Action("Soporte", "Home")" role="menuitem">Contacto</a></li>
        </ul>
        @if (Session["Nombre"] != null)
        {
            <a href="@Url.Action("Perfil", "Ciudadano")" class="btn-login" aria-label="Ir a mi perfil de usuario">Mi Perfil</a>
        }
        else
        {
            <a href="@Url.Action("Login", "Account")" class="btn-login" aria-label="Iniciar sesión en tu cuenta">Iniciar sesión</a>
        }
    </nav>

    @RenderBody()

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
