    @* Mensajes flash *@
    @if (TempData["AdopcionSuccess"] != null)
    {
        <script>
            alert('@TempData["AdopcionSuccess"]');
        </script>
    }
    @if (TempData["AdopcionWarning"] != null)
    {
        <script>
            alert('@TempData["AdopcionWarning"]');
        </script>
    }

    <script>
        // Función para anunciar mensajes a lectores de pantalla
        function announce(message) {
            const announcements = document.getElementById('announcements');
            announcements.textContent = message;
            setTimeout(() => {
                announcements.textContent = '';
            }, 1000);
        }

        // Función para manejar el botón de like/favoritos
        function toggleLike(button) {
            const mascotaName = button.getAttribute('data-mascota');
            const isLiked = button.classList.contains('liked');

            if (isLiked) {
                // Remover de favoritos
                button.classList.remove('liked');
                button.querySelector('span').textContent = '♡';
                button.setAttribute('aria-label', 'Agregar ' + mascotaName + ' a favoritos');
                announce(mascotaName + ' ha sido removido de favoritos');

                // Remover del localStorage
                let favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
                favorites = favorites.filter(name => name !== mascotaName);
                localStorage.setItem('favorites', JSON.stringify(favorites));
            } else {
                // Agregar a favoritos
                button.classList.add('liked');
                button.querySelector('span').textContent = '♥';
                button.setAttribute('aria-label', 'Remover ' + mascotaName + ' de favoritos');
                announce(mascotaName + ' ha sido agregado a favoritos');

                // Guardar en localStorage
                let favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
                if (!favorites.includes(mascotaName)) {
                    favorites.push(mascotaName);
                    localStorage.setItem('favorites', JSON.stringify(favorites));
                }
            }
        }

        // Cargar favoritos guardados al cargar la página
        document.addEventListener('DOMContentLoaded', function() {
            const favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
            const likeButtons = document.querySelectorAll('.like-btn');

            likeButtons.forEach(button => {
                const mascotaName = button.getAttribute('data-mascota');
                if (favorites.includes(mascotaName)) {
                    button.classList.add('liked');
                    button.querySelector('span').textContent = '♥';
                    button.setAttribute('aria-label', 'Remover ' + mascotaName + ' de favoritos');
                }
            });

            // Mejorar navegación por teclado
            const focusableElements = 'a[href], button:not([disabled]), textarea:not([disabled]), input:not([disabled]), select:not([disabled])';
            const focusable = document.querySelectorAll(focusableElements);

            // Agregar indicadores visuales de focus
            focusable.forEach(element => {
                element.addEventListener('focus', function() {
                    this.style.outline = '3px solid #FA8C99';
                    this.style.outlineOffset = '2px';
                });
                element.addEventListener('blur', function() {
                    this.style.outline = '';
                    this.style.outlineOffset = '';
                });
            });
        });

        // Mejorar accesibilidad de la navegación por teclado en cards
        document.addEventListener('keydown', function(e) {
            // Activar botones con Enter o Espacio
            if ((e.key === 'Enter' || e.key === ' ') && e.target.classList.contains('like-btn')) {
                e.preventDefault();
                e.target.click();
            }
        });
    </script>
