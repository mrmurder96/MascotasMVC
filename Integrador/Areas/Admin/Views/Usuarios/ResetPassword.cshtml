@model Integrador.Models.Usuarios
@{
    ViewBag.Title = "Restablecer Contraseńa";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2><i class="fas fa-key"></i> Restablecer Contraseńa de Usuario</h2>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="alert alert-info">
                <strong>Usuario:</strong> @Model.Nombres @Model.Apellidos (@Model.Email)
            </div>

            @using (Html.BeginForm("ResetPassword", "Usuarios", FormMethod.Post, new { @class = "form-horizontal" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.Id)

                <div class="form-horizontal">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group">
                        <label class="control-label col-md-2" for="NewPassword">Nueva Contraseńa</label>
                        <div class="col-md-10">
                            <input type="password" name="NewPassword" id="NewPassword" class="form-control" required minlength="6" />
                            <span class="help-block">La contraseńa debe tener al menos 6 caracteres</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="control-label col-md-2" for="ConfirmPassword">Confirmar Contraseńa</label>
                        <div class="col-md-10">
                            <input type="password" name="ConfirmPassword" id="ConfirmPassword" class="form-control" required minlength="6" />
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="col-md-offset-2 col-md-10">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Restablecer Contraseńa
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-default">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function() {
            $('form').on('submit', function(e) {
                var newPassword = $('#NewPassword').val();
                var confirmPassword = $('#ConfirmPassword').val();
                
                if (newPassword !== confirmPassword) {
                    e.preventDefault();
                    alert('Las contraseńas no coinciden');
                    return false;
                }
            });
        });
    </script>
}
